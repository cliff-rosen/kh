files:
  "/etc/systemd/system/kh-worker.service":
    mode: "000644"
    owner: root
    group: root
    content: |
      [Unit]
      Description=Knowledge Horizon Worker Process
      After=network.target

      [Service]
      Type=simple
      User=webapp
      WorkingDirectory=/var/app/current
      ExecStart=/var/app/venv/bin/python -m worker.main
      Restart=always
      RestartSec=5
      Environment=PYTHONPATH=/var/app/current

      # Graceful shutdown: send SIGTERM, wait 60s for pipeline to finish
      TimeoutStopSec=60
      KillSignal=SIGTERM

      # Logging to journald (viewable via journalctl -u kh-worker)
      StandardOutput=journal
      StandardError=journal
      SyslogIdentifier=kh-worker

      [Install]
      WantedBy=multi-user.target

container_commands:
  01_start_worker:
    command: "systemctl daemon-reload && systemctl enable kh-worker && systemctl restart kh-worker"

